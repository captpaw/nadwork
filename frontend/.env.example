# IMPORTANT: NadWork frontend runs V4-only. Sync addresses via: npm run sync:frontend:addresses
# ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Frontend environment Гўв‚¬вЂќ copy to frontend/.env and fill in values ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
# cp frontend/.env.example frontend/.env

# RPC: If unset, uses mainnet. For Testnet set one of:
#   VITE_RPC_URL=https://testnet-rpc.monad.xyz
#   VITE_USE_TESTNET=1
# VITE_RPC_URL=
# Optional extra RPCs (comma-separated) for fallback rotation
# VITE_RPC_FALLBACK_URLS=https://rpc1.monad.xyz,https://rpc2.monad.xyz

# Dev proxy (bypasses CORS on localhost). Default: enabled in dev. Disable with:
# VITE_USE_RPC_PROXY=0
# VITE_USE_SUBGRAPH_PROXY=0
# VITE_USE_IPFS_PROXY=0  # dev: route metadata fetch via /ipfs-proxy
# VITE_IPFS_PROXY_URL=    # optional external metadata proxy (prod/dev)

# Required Гўв‚¬вЂќ create a project at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Pinata IPFS (local dev only Гўв‚¬вЂќ use proxy in production)
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET_API_KEY=
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Production IPFS proxy (frontend only needs URL; auth stays in worker secrets)
VITE_PIN_PROXY_URL=

# Contract Addresses Гўв‚¬вЂќ filled by deploy script or set manually
VITE_BOUNTY_FACTORY_ADDRESS=
VITE_BOUNTY_REGISTRY_ADDRESS=
VITE_ESCROW_ADDRESS=
VITE_REPUTATION_REGISTRY_ADDRESS=
VITE_IDENTITY_REGISTRY_ADDRESS=

# Goldsky Subgraph (Indexer)
# Kosong ГўвЂ вЂ™ fallback ke RPC. Isi setelah subgraph deploy di Goldsky.
# VITE_GOLDSKY_SUBGRAPH_URL=

# Token Addresses
VITE_USDC_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603



# Force public deployment to show full-screen Coming Soon page
# Set true on Cloudflare Pages production env, keep false/empty for localhost dev
# VITE_COMING_SOON=false


