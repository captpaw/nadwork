#!/usr/bin/env bash
# ─── NadWork Pre-Commit Security Hook ────────────────────────────────────────
# Blocks commits that contain secrets, private keys, or sensitive file patterns.
# Install: git config core.hooksPath .githooks
# Compatible with: Linux, macOS, Windows (Git Bash)
# ─────────────────────────────────────────────────────────────────────────────

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

echo "Running security pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}No staged files. Skipping.${NC}"
  exit 0
fi

# ─── 1. Block dangerous file names ───────────────────────────────────────────
DANGEROUS_PATTERNS=(
  "^\.env$"
  "^\.env\.production$"
  "^\.env\.staging$"
  "^\.env\.local$"
  "\.env\.local$"
  "\.env\.production$"
  "private_key\.txt$"
  "mnemonic\.txt$"
  "seed\.txt$"
  "wallet\.json$"
  "^keystore/"
  "secrets\.json$"
  "secrets\.ya?ml$"
  "\.pem$"
  "\.key$"
  "\.p12$"
  "\.pfx$"
  "\.dev\.vars$"
)

for file in $STAGED_FILES; do
  for pattern in "${DANGEROUS_PATTERNS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo -e "${RED}BLOCKED: Sensitive file detected: $file${NC}"
      ERRORS=$((ERRORS + 1))
    fi
  done
done

# ─── 2. Scan staged diffs for secret patterns ─────────────────────────────────
SECRET_PATTERNS=(
  "PRIVATE_KEY[[:space:]]*=[[:space:]]*[0-9a-fA-F]{60,}"
  "BEGIN[[:space:]]+(RSA[[:space:]]+|EC[[:space:]]+|OPENSSH[[:space:]]+)?PRIVATE KEY"
  "AKIA[0-9A-Z]{16}"
  "aws_secret_access_key[[:space:]]*=[[:space:]]*[A-Za-z0-9/+=]{40}"
  "pinata_secret[[:space:]]*[=:][[:space:]]*[0-9a-fA-F]{32,}"
  "PINATA_SECRET[[:space:]]*=[[:space:]]*[0-9a-fA-F]{32,}"
)

for file in $STAGED_FILES; do
  # Only scan files with known text extensions
  case "$file" in
    *.js|*.jsx|*.ts|*.tsx|*.sol|*.json|*.toml|*.yaml|*.yml|*.sh|*.md|*.txt|*.env*|*.config)
      DIFF_CONTENT=$(git diff --cached -- "$file" 2>/dev/null | grep "^+" | grep -v "^+++" || true)
      if [ -n "$DIFF_CONTENT" ]; then
        for pattern in "${SECRET_PATTERNS[@]}"; do
          if echo "$DIFF_CONTENT" | grep -qiE "$pattern"; then
            echo -e "${RED}BLOCKED: Possible secret found in: $file${NC}"
            echo -e "${YELLOW}  Pattern: $pattern${NC}"
            ERRORS=$((ERRORS + 1))
            break
          fi
        done
      fi
      ;;
  esac
done

# ─── Result ───────────────────────────────────────────────────────────────────
if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo -e "${RED}COMMIT BLOCKED — $ERRORS security issue(s) detected${NC}"
  echo ""
  echo -e "${YELLOW}To bypass (only if certain this is a false positive):${NC}"
  echo -e "${YELLOW}  git commit --no-verify${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}Security checks passed.${NC}"
exit 0
