# â”€â”€â”€ Copy this file to .env and fill in the values â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# cp .env.example .env
# NEVER commit the .env file â€” it contains private keys and API secrets.

# â”€â”€â”€ Deployment â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Deployer private key â€” 64 hex characters, WITHOUT the 0x prefix.
# This wallet pays gas and becomes the initial contract owner/treasury.
PRIVATE_KEY=

# Monad RPC endpoint (default works for public mainnet)
# For testnet, use: https://testnet-rpc.monad.xyz
MONAD_RPC_URL=https://rpc.monad.xyz

# Routescan / Monad explorer API key for contract verification (optional)
MONAD_EXPLORER_API_KEY=

# Platform fee recipient wallet address.
# Defaults to the deployer address if left blank.
TREASURY_ADDRESS=

# â”€â”€â”€ Frontend (Vite) â€” all VITE_* vars are bundled into the browser â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# RPC for contract reads. Defaults to mainnet if unset.
# For Monad Testnet: VITE_RPC_URL=https://testnet-rpc.monad.xyz

# Required â€” create a project at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Pinata IPFS â€” used for bounty metadata & submission attachments.
# For LOCAL DEV only. In production use the Cloudflare Worker proxy instead
# so the secret never ships in the browser bundle.
VITE_PINATA_API_KEY=
# VITE_PINATA_SECRET_API_KEY â€” DEV ONLY, leave blank in production
VITE_PINATA_SECRET_API_KEY=
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Production IPFS proxy (Cloudflare Worker)
# Set this to avoid shipping Pinata secrets to the browser.
# See workers/pin-proxy/ for the Worker source code.
VITE_PIN_PROXY_URL=
# Optional metadata read proxy (for IPFS JSON fetch path) 
# VITE_IPFS_PROXY_URL=
# VITE_USE_IPFS_PROXY=0  # dev-only toggle for /ipfs-proxy

# â”€â”€â”€ Contract Addresses â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# These are filled automatically by `npm run deploy:monad`.
# Standard workflow: run npm run sync:frontend:addresses after deploy to enforce V4-only frontend config.
# You can also set them manually after a deploy.
VITE_BOUNTY_FACTORY_ADDRESS=
VITE_BOUNTY_REGISTRY_ADDRESS=
VITE_ESCROW_ADDRESS=
VITE_REPUTATION_REGISTRY_ADDRESS=
VITE_IDENTITY_REGISTRY_ADDRESS=

# â”€â”€â”€ Goldsky Subgraph (Indexer) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Public GraphQL endpoint from Goldsky. Fill after: goldsky subgraph deploy nadwork-mainnet/1.0.0
# For testnet: use nadwork-testnet/1.0.0 endpoint instead.
# Free for Monad builders â€” Monad Foundation covers 100% of Goldsky cost.
# If left blank, the frontend falls back to direct RPC calls (slower).
VITE_GOLDSKY_SUBGRAPH_URL=

# â”€â”€â”€ Token Addresses â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Monad testnet/mainnet USDC
VITE_USDC_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603



